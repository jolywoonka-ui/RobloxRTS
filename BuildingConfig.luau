-- Helper functions (unchanged)
function Config.CalculateUnitLimit(buildingsList)
	local total = Config.BaseUnitLimit
	for buildingName, count in pairs(buildingsList) do
		local data = Config.Buildings[buildingName]
		if data and data.UnitLimit then
			total += data.UnitLimit * count
		end
	end
	return total
end

function Config.CalculateEnergyConsumption(buildingsList)
	local total = 0
	for buildingName, count in pairs(buildingsList) do
		local data = Config.Buildings[buildingName]
		if data and data.Energy then
			if data.Energy < 0 then
				total += math.abs(data.Energy) * count
			end
		end
	end
	return total
end

function Config.CalculateEnergyGeneration(buildingsList)
	local total = 0
	for buildingName, count in pairs(buildingsList) do
		local data = Config.Buildings[buildingName]
		if data and data.Energy then
			if data.Energy > 0 then
				total += data.Energy * count
			end
		end
	end
	return total
end

return Config










